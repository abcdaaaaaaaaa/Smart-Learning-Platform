RewriteEngine On
AddHandler application/x-httpd-ea-php74 .php .php7 .phtml

RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]

RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/index1\.html[\s?] [NC]
RewriteRule ^index1\.html$ /vocabulary [R=301,L]

RewriteCond %{THE_REQUEST} \s/index2\.html[\s?] [NC]
RewriteRule ^index2\.html$ /formation [R=301,L]

RewriteCond %{THE_REQUEST} \s/index3\.html[\s?] [NC]
RewriteRule ^index3\.html$ /gap-filling [R=301,L]

RewriteCond %{THE_REQUEST} \s/ads\.html[\s?] [NC]
RewriteRule ^ads\.html$ /ads [R=301,L]

RewriteRule ^vocabulary/?$  index1.html  [L,NC]
RewriteRule ^formation/?$   index2.html  [L,NC]
RewriteRule ^gap-filling/?$ index3.html  [L,NC]
RewriteRule ^ads/?$         ads.html     [L,NC]

ErrorDocument 404 https://learnvocabulary.org
ErrorDocument 403 https://learnvocabulary.org

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ / [R=301,L]
